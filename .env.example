# ── Django ──────────────────────────────────────────────────────────
# Generate a real secret key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key

# Set to False in production, True for local dev
DJANGO_DEBUG=True

# Comma-separated list of frontend origins allowed for CORS / CSRF
FRONTEND_URLS=http://localhost:3000,http://localhost:3001

# Set to True in production (requires HTTPS); False for local dev
SESSION_COOKIE_SECURE=False

# ── SMTP credentials (set these for email sending) ─────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@terionix.com
